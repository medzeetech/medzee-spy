# ──────────────────────────────────────────────────────────────
# Medzee Spy — backend env (exemplo)
# Copie para .env e preencha os valores reais. Não commite .env.
# ──────────────────────────────────────────────────────────────

# App
PROJECT_NAME=MedZee Spy API
VERSION=0.1.0
DEBUG=true

# CORS (frontend Vite roda em 5173 por default; manter 3000 por compat)
ALLOWED_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# ──────────────────────────────────────────────────────────────
# Supabase (mesma instância do projeto "News" — D3)
# Tabelas medzee_* serão criadas com prefixo
# ──────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ──────────────────────────────────────────────────────────────
# WhatsApp via uazapi.com (D1 — substitui o sidecar Baileys)
# Admin token é usado para criar instâncias on-demand.
# Cada sessão de usuário recebe seu próprio instance_token,
# persistido em medzee_whatsapp_sessions.uazapi_token.
# ──────────────────────────────────────────────────────────────
UAZAPI_BASE_URL=https://your-subdomain.uazapi.com
UAZAPI_ADMIN_TOKEN=your-admin-token

# ──────────────────────────────────────────────────────────────
# LLM (D2 — Anthropic Claude por default, abstraível)
# ──────────────────────────────────────────────────────────────
LLM_PROVIDER=anthropic
LLM_MODEL=claude-sonnet-4-6
ANTHROPIC_API_KEY=
