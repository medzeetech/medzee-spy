# ──────────────────────────────────────────────────────────────
# Medzee Spy — backend env (exemplo)
# Copie pra .env e preencha. NÃO commite o .env.
# Pra prod (Railway), configure as mesmas vars no Dashboard.
# Atenção (L5 em STATE.md): no Railway, evite aspas literais
# em campos individuais; use Raw Editor pra não vazar "value".
# ──────────────────────────────────────────────────────────────

# App
PROJECT_NAME=Medzee Spy API
VERSION=0.1.0
DEBUG=true

# URL pública do backend — usada pra montar callback do webhook uazapi.
# Local: http://localhost:8000 (uazapi não consegue alcançar — só usar webhook em prod ou via ngrok).
# Prod: URL Railway pública (ex.: https://medzee-spy.up.railway.app).
API_BASE_URL=http://localhost:8000

# CORS — frontend Vite roda em 5173 por default. Inclua sua URL prod do front.
ALLOWED_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# ──────────────────────────────────────────────────────────────
# Supabase (mesma instância do projeto "News" — vide D3 STATE.md)
# Schema dedicado: medzee_spy.*
# ──────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ──────────────────────────────────────────────────────────────
# WhatsApp via uazapi.com (D1 — substituiu o sidecar Baileys)
# ADMIN_TOKEN cria instâncias on-demand. Cada sessão recebe seu próprio
# instance_token (36 chars UUID), persistido em medzee_spy.whatsapp_sessions.
# Tier paid recomendado (free trunca /chat/find e tem quota baixa de slots).
# ──────────────────────────────────────────────────────────────
UAZAPI_BASE_URL=https://your-subdomain.uazapi.com
UAZAPI_ADMIN_TOKEN=your-admin-token

# HTTP timeout por request individual (s). Default 8s cobre o normal;
# o retry/budget de 5xx é configurado em código (_RETRY_DELAYS_S).
UAZAPI_HTTP_TIMEOUT_S=8.0

# ──────────────────────────────────────────────────────────────
# Extract worker (legado F1 — deprecated, mantido pra rollback)
# Esses params NÃO afetam o F5 pull_last_n_per_chat (que tem seus
# próprios constants em extract.py).
# ──────────────────────────────────────────────────────────────
EXTRACT_DAYS_WINDOW=30
EXTRACT_PARALLELISM=5
EXTRACT_SOFT_TIMEOUT_S=90
EXTRACT_HARD_TIMEOUT_S=420

# Tempo até sessão pending expirar (sem scan QR).
SESSION_TTL_MINUTES=15

# ──────────────────────────────────────────────────────────────
# Reports (F4/F5)
# Threshold mínimo de msgs no /api/reports/generate. F5 removeu o block
# rígido, mas o threshold ainda é usado pra log de snapshot.
# ──────────────────────────────────────────────────────────────
REPORTS_GENERATE_MIN_MESSAGES=10
REPORTS_GENERATE_RATE_S=60

# ──────────────────────────────────────────────────────────────
# LLM (D2 — Anthropic Claude por default)
# Modelo recomendado: claude-sonnet-4-6 (1M context, custo OK pra PT-BR).
# ──────────────────────────────────────────────────────────────
LLM_PROVIDER=anthropic
LLM_MODEL=claude-sonnet-4-6
ANTHROPIC_API_KEY=
