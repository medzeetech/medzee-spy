# ──────────────────────────────────────────────────────────────
# Medzee Spy — backend env (exemplo)
# Copie pra .env e preencha. NÃO commite o .env.
# Pra prod (Railway), configure as mesmas vars no Dashboard.
# Atenção (L5 em STATE.md): no Railway, evite aspas literais
# em campos individuais; use Raw Editor pra não vazar "value".
# ──────────────────────────────────────────────────────────────

# App
PROJECT_NAME=Medzee Spy API
VERSION=0.1.0
DEBUG=true

# URL pública do backend — usada pra CORS/extensão.
# Local: http://localhost:8000.
# Prod: URL Railway pública (ex.: https://medzee-spy.up.railway.app).
API_BASE_URL=http://localhost:8000

# CORS — frontend Vite roda em 5173 por default. Inclua sua URL prod do front.
ALLOWED_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# ──────────────────────────────────────────────────────────────
# Supabase (mesma instância do projeto "News" — vide D3 STATE.md)
# Schema dedicado: medzee_spy.*
# ──────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ──────────────────────────────────────────────────────────────
# F8 — Chrome Extension
# PIVOT (2026-05-24): o dance de pairing JWT custom foi removido.
# A extensão agora loga via email+password direto no Supabase e usa
# o access_token padrão como Bearer — sem variável de ambiente extra.
#
# Tuning opcional (defaults sãos em código):
# EXTENSION_MIN_VERSION=1.0.0
# EXTENSION_TELEMETRY_RATE_PER_MINUTE=60
# ──────────────────────────────────────────────────────────────

# ──────────────────────────────────────────────────────────────
# Reports (F4/F5)
# Threshold mínimo de msgs no /api/reports/generate. F5 removeu o block
# rígido, mas o threshold ainda é usado pra log de snapshot.
# ──────────────────────────────────────────────────────────────
REPORTS_GENERATE_MIN_MESSAGES=10
REPORTS_GENERATE_RATE_S=60

# Captured messages — retenção em dias. TTL worker apaga rows mais antigas.
# CAPTURED_MESSAGES_TTL_DAYS=30

# ──────────────────────────────────────────────────────────────
# LLM (D2 — Anthropic Claude por default)
# Modelo recomendado: claude-sonnet-4-6 (1M context, custo OK pra PT-BR).
# ──────────────────────────────────────────────────────────────
LLM_PROVIDER=anthropic
LLM_MODEL=claude-sonnet-4-6
ANTHROPIC_API_KEY=
