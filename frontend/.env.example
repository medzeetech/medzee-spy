# ──────────────────────────────────────────────────────────────
# Medzee Spy — frontend env (exemplo)
# Copie pra .env e preencha. Vite só expõe vars com prefixo VITE_.
# NÃO commite o .env.
# ──────────────────────────────────────────────────────────────

# URL do backend FastAPI.
# Local: http://localhost:8000
# Prod: URL pública do backend Railway
VITE_API_BASE_URL=http://localhost:8000

# Supabase client (F2+): usado pra setSession após signup/login e
# pra refresh de token em background no useReportPolling.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Voice agent Marina (ElevenLabs). Opcional no dev — sem isso, o
# AgentScreen renderiza mas o widget não conecta.
# Em prod, agent_id real (ex.: agent_8601krmch56bfbbv5wjya2jw0y3x).
VITE_ELEVENLABS_AGENT_ID=your-elevenlabs-agent-id
