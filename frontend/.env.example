# ──────────────────────────────────────────────────────────────
# Medzee Spy — frontend env (exemplo)
# Copie para .env e preencha os valores reais. Não commite .env.
# Vite só expõe ao bundle vars que comecem com VITE_.
# ──────────────────────────────────────────────────────────────

# URL do backend FastAPI
VITE_API_BASE_URL=http://localhost:8000

# Agente de voz Marina (ElevenLabs) — hoje hardcoded em AgentScreen.jsx
VITE_ELEVENLABS_AGENT_ID=your-elevenlabs-agent-id

# Supabase client (a usar a partir da F2 para setSession após signup)
# VITE_SUPABASE_URL=https://your-project.supabase.co
# VITE_SUPABASE_ANON_KEY=your-anon-key
