# ──────────────────────────────────────────────────────────────
# Medzee Spy — extension build-time env (exemplo)
# Copie pra .env e preencha. Lido pelo Vite no build (substituído
# como string literal no JS final).
# ──────────────────────────────────────────────────────────────

# URL pública do backend (FastAPI/Railway). Usada pelo service-worker
# pra POSTar em /api/extension/*.
#
# Sem trailing slash. O código adiciona /api/... na frente.
#
# Defaults:
#   - Prod recomendado: https://medzee-spy-production.up.railway.app
#   - Local dev: http://localhost:8000
VITE_BACKEND_URL=https://medzee-spy-production.up.railway.app

# URL pública do frontend (Vercel). Usada pelo popup pra abrir o app
# nos botões "Conectar agora" / "Atualizar análise".
#
# Defaults:
#   - Prod: https://medzee-spy.vercel.app
#   - Local dev: http://localhost:5173
VITE_FRONTEND_URL=https://medzee-spy.vercel.app
